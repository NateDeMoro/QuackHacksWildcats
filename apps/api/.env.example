# Copy to `.env`, fill in, never commit. Load: tsx watch --env-file=.env src/server.ts
# STT/Firestore/Auth creds come from ADC. GEMINI_API_KEY below IS a secret — keep it out of git.

# GCP project id (STT recognizer path; Firestore/Auth ADC).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini Developer API (AI Studio) key — the free-tier path, used only when GEMINI_USE_VERTEX=0.
# Get one at https://aistudio.google.com/apikey . Unset (on the key path) = stub report.
GEMINI_API_KEY=your-ai-studio-api-key

# Gemini model id (Stage 2). Must be available in the Vertex location when GEMINI_USE_VERTEX=1.
GEMINI_MODEL=gemini-2.5-flash

# 1 = run Gemini on Vertex AI via ADC (no API key) instead of the AI Studio key. Needs the Vertex AI
# API enabled + roles/aiplatform.user on the ADC identity, and GOOGLE_CLOUD_PROJECT set.
GEMINI_USE_VERTEX=0

# Vertex AI location for Gemini (only when GEMINI_USE_VERTEX=1). Defaults to us-central1.
GOOGLE_CLOUD_LOCATION=us-central1

# 1 = skip Speech-to-Text, return a mock transcript (offline dev).
STT_MOCK=0

# 1 = skip Gemini, return a deterministic stub report (offline dev).
GEMINI_MOCK=0

# 1 = skip Firestore, disable session persistence (offline dev).
FIRESTORE_MOCK=0

# 1 = skip Firebase ID-token verification; inject AUTH_MOCK_UID instead (offline dev).
AUTH_MOCK=0
AUTH_MOCK_UID=dev-user

# Server port (Cloud Run injects this; 8080 locally).
PORT=8080

# Path to the email allowlist JSON ({"emails":[...]}). Default: ./allowlist.json (process cwd).
# Copy allowlist.example.json -> allowlist.json and fill in. In production a missing file denies all.
ALLOWLIST_PATH=
