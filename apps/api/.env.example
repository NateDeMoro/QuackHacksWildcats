# Copy to `.env`, fill in, never commit. Load: tsx watch --env-file=.env src/server.ts
# Credentials come from ADC, not this file — nothing here is a secret.

# GCP project id (STT recognizer path + Stage 2 Vertex AI calls).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini model id (Stage 2), served via Vertex AI under ADC.
GEMINI_MODEL=gemini-2.5-flash

# 1 = skip Speech-to-Text, return a mock transcript (offline dev).
STT_MOCK=0

# 1 = skip Gemini, return a deterministic stub report (offline dev).
GEMINI_MOCK=0

# 1 = skip Firestore, disable session persistence (offline dev).
FIRESTORE_MOCK=0

# 1 = skip Firebase ID-token verification; inject AUTH_MOCK_UID instead (offline dev).
AUTH_MOCK=0
AUTH_MOCK_UID=dev-user

# Server port (Cloud Run injects this; 8080 locally).
PORT=8080
